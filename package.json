{
  "name": "capyvo",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.58.0"
  },
  "lint-staged": {
    "client/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0 --config client/eslint.config.js"
    ],
    "server/**/*.ts": [
      "prettier --write",
      "eslint --fix --max-warnings=0 --config server/eslint.config.mjs"
    ],
    "**/*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
