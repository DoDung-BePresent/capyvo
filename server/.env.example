PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
LOG_LEVEL=debug

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Supabase Management API — để xem storage usage trên admin dashboard
# Lấy tại: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxx
# Tự parse từ SUPABASE_URL nếu để trống
SUPABASE_PROJECT_REF=

# Prisma / Database (lấy từ Supabase → Settings → Database)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Redis (Upstash - https://upstash.com)
REDIS_URL=redis://default:xxx@xxx.upstash.io:6379

# Queue Settings
QUEUE_CONCURRENCY=5

# AI Services
OPENAI_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# PayOS (https://my.payos.vn)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
# URL prefix khi PayOS redirect sau thanh toán
PAYOS_RETURN_URL=http://localhost:5173/payment/result
PAYOS_CANCEL_URL=http://localhost:5173/payment/cancel