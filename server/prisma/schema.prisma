// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum ExamSetType {
  PRACTICE
  FORECAST
  CUSTOM
}

enum QuestionType {
  PRACTICE
  FORECAST
  CUSTOM
}

enum QuestionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum SubscriptionPlanId {
  FREE
  TRIAL
  PREMIUM
  CLASSROOM
}

enum MaintenanceScope {
  GLOBAL      // Toàn bộ hệ thống
  PRICING     // Trang pricing và payment
  PRACTICE    // Trang practice
  EXAM        // Trang exam/test
  ADMIN       // Trang admin
}

// ─── Models ───────────────────────────────────────────────────────────────────

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model User {
  id                   String    @id
  email                String    @unique
  fullName             String?
  avatarUrl            String?
  role                 Role      @default(USER)
  
  // Cache fields (computed from subscriptions for fast queries)
  isPremium            Boolean   @default(false)
  premiumUntil         DateTime? @db.Date
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  practiceSessions PracticeSession[]
  payments         Payment[]
  subscriptions    Subscription[]
  publicShares     PublicShare[]
  reactions        Reaction[]

  @@map("users")
}

model ExamSet {
  id          String      @id @default(uuid())
  title       String
  description String?
  type        ExamSetType @default(PRACTICE)
  isPublished Boolean     @default(false)
  isComplete  Boolean     @default(false) // true if has all 11 questions
  createdBy   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  questionAssignments QuestionAssignment[]
  practiceSessions    PracticeSession[]

  @@map("exam_sets")
}

model Question {
  id             String   @id @default(uuid())
  partNumber     Int // 1-5
  questionNumber Int // Question number within the part (not globally unique)
  
  // Question grouping (Part 3, 4 only)
  setId          String? // Groups 3 questions together (Part 3: Q5-7, Part 4: Q8-10)
  
  // Question type and status
  type           QuestionType   @default(PRACTICE)
  status         QuestionStatus @default(DRAFT)
  
  // Part 1: read aloud
  contentText    String?
  // Part 3, 4: context
  contextText     String?
  contextAudioUrl String?
  // Part 3, 4, 5: question audio
  questionText    String?
  questionAudioUrl String?
  // Part 2, 4: images
  imageUrls       String[] @default([])
  imageContext    String?  // AI-generated description of the image(s) for scoring context
  // Timing
  prepTimeSeconds     Int
  responseTimeSeconds Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  examSetAssignments QuestionAssignment[]
  topicAssignments   QuestionTopicAssignment[]
  userResponses      UserResponse[]
  publicShares       PublicShare[]

  @@index([partNumber])
  @@index([type])
  @@index([status])
  @@index([partNumber, status])
  @@index([setId])
  @@map("questions")
}

// Junction table for many-to-many relationship between Question and ExamSet
model QuestionAssignment {
  id             String   @id @default(uuid())
  examSetId      String
  questionId     String
  questionNumber Int      // Position in this specific exam set (1-11)
  createdAt      DateTime @default(now())

  examSet  ExamSet  @relation(fields: [examSetId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([examSetId, questionNumber])
  @@index([examSetId])
  @@index([questionId])
  @@map("question_assignments")
}

model Topic {
  id          String   @id @default(uuid())
  name        String
  partNumber  Int
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questionAssignments QuestionTopicAssignment[]

  @@unique([name, partNumber])
  @@map("topics")
}

// Junction table for many-to-many relationship between Question and Topic
model QuestionTopicAssignment {
  id         String   @id @default(uuid())
  questionId String
  topicId    String
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  topic    Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([questionId, topicId])
  @@index([questionId])
  @@index([topicId])
  @@map("question_topic_assignments")
}

model PartInstruction {
  partNumber Int      @id // 1-5
  audioUrl   String?
  updatedAt  DateTime @updatedAt

  @@map("part_instructions")
}

model SystemAudio {
  key       String   @id // e.g. START_SPEAKING, START_RESPONSE
  audioUrl  String?
  updatedAt DateTime @updatedAt

  @@map("system_audio")
}

model PracticeSession {
  id          String        @id @default(uuid())
  userId      String
  examSetId   String?       // null = practice mode (individual questions), non-null = exam mode
  partNumber  Int?          // null = full exam, 1-5 = specific part
  status      SessionStatus @default(IN_PROGRESS)
  startedAt   DateTime      @default(now())
  completedAt DateTime?

  user          User           @relation(fields: [userId], references: [id])
  examSet       ExamSet?       @relation(fields: [examSetId], references: [id])
  userResponses UserResponse[]

  @@map("practice_sessions")
}

model UserResponse {
  id                  String   @id @default(uuid())
  sessionId           String
  questionId          String
  audioUrl            String?
  transcript          String?
  pronunciationScore  Json?
  contentScore        Json?
  overallScore        Float?
  feedback            String?
  evaluatedAt         DateTime?
  createdAt           DateTime @default(now())

  session      PracticeSession @relation(fields: [sessionId], references: [id])
  question     Question        @relation(fields: [questionId], references: [id])
  publicShare  PublicShare?

  @@map("user_responses")
}

model Payment {
  id              String        @id @default(uuid())
  userId          String
  orderCode       BigInt        @unique // PayOS order code (numeric)
  amount          Int           // VND
  description     String
  status          PaymentStatus @default(PENDING)
  tokenAmount     Int?          // Deprecated
  subscriptionId  String?       // Link to subscription if this payment is for subscription
  checkoutUrl     String?
  payosTransactionId String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@map("payments")
}

model SubscriptionPlan {
  id            SubscriptionPlanId @id
  name          String
  durationDays  Int
  price         Int                // VND
  pricePerMonth Int                // VND
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id        String             @id @default(uuid())
  userId    String
  planId    SubscriptionPlanId
  status    SubscriptionStatus @default(ACTIVE)
  
  startDate DateTime
  endDate   DateTime
  
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan  @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([userId])
  @@index([status])
  @@index([planId])
  @@index([endDate])
  @@index([userId, status, endDate])
  @@map("subscriptions")
}

model PublicShare {
  id          String   @id @default(uuid())
  responseId  String   @unique
  userId      String
  questionId  String
  createdAt   DateTime @default(now())
  
  response    UserResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  question    Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  reactions   Reaction[]
  
  @@index([questionId])
  @@index([createdAt])
  @@map("public_shares")
}

model Reaction {
  id        String   @id @default(uuid())
  shareId   String
  userId    String
  emoji     String   // "1️⃣", "2️⃣", "3️⃣", "4️⃣", "5️⃣", "😍", "💖", "🤔"
  createdAt DateTime @default(now())
  
  share     PublicShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([shareId, userId])
  @@index([shareId])
  @@map("reactions")
}

model MaintenanceSchedule {
  id        String            @id @default(uuid())
  scope     MaintenanceScope  @default(GLOBAL)
  title     String            // e.g. "Bảo trì PayOS", "Nâng cấp hệ thống"
  message   String            // Message hiển thị cho user
  startAt   DateTime?         // null = bật ngay
  endAt     DateTime?         // null = không tự động tắt
  isActive  Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  
  @@index([scope])
  @@index([isActive])
  @@index([scope, isActive])
  @@map("maintenance_schedules")
}
