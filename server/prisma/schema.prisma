// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum ExamSetType {
  PRACTICE
  FORECAST
  CUSTOM
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum SubscriptionPlanId {
  MONTHLY
  QUARTERLY
  BIANNUAL
}

// ─── Models ───────────────────────────────────────────────────────────────────

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model User {
  id                   String    @id
  email                String    @unique
  fullName             String?
  role                 Role      @default(USER)
  transcriptionCredits Int       @default(5) // Deprecated - sẽ xóa sau khi migrate
  
  // Subscription fields
  isPremium            Boolean   @default(false)
  premiumUntil         DateTime?
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  practiceSessions PracticeSession[]
  payments         Payment[]
  subscriptions    Subscription[]

  @@map("users")
}

model ExamSet {
  id          String      @id @default(uuid())
  title       String
  description String?
  type        ExamSetType @default(PRACTICE)
  isPublished Boolean     @default(false)
  createdBy   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  questions        Question[]
  practiceSessions PracticeSession[]

  @@map("exam_sets")
}

model Question {
  id             String   @id @default(uuid())
  examSetId      String?
  partNumber     Int // 1-5
  questionNumber Int // 1-11
  // Part 1: read aloud
  contentText    String?
  // Part 3, 4: context
  contextText     String?
  contextAudioUrl String?
  // Part 3, 4, 5: question audio
  questionText    String?
  questionAudioUrl String?
  // Part 2, 4: images
  imageUrls       String[] @default([])
  imageContext    String?  // AI-generated description of the image(s) for scoring context
  // Timing
  prepTimeSeconds     Int
  responseTimeSeconds Int
  createdAt        DateTime @default(now())

  examSet       ExamSet?       @relation(fields: [examSetId], references: [id], onDelete: SetNull)
  userResponses UserResponse[]

  @@unique([examSetId, questionNumber])
  @@map("questions")
}

model PartInstruction {
  partNumber Int      @id // 1-5
  audioUrl   String?
  updatedAt  DateTime @updatedAt

  @@map("part_instructions")
}

model SystemAudio {
  key       String   @id // e.g. START_SPEAKING, START_RESPONSE
  audioUrl  String?
  updatedAt DateTime @updatedAt

  @@map("system_audio")
}

model PracticeSession {
  id          String        @id @default(uuid())
  userId      String
  examSetId   String
  partNumber  Int?          // null = full exam, 1-5 = specific part
  status      SessionStatus @default(IN_PROGRESS)
  startedAt   DateTime      @default(now())
  completedAt DateTime?

  user          User           @relation(fields: [userId], references: [id])
  examSet       ExamSet        @relation(fields: [examSetId], references: [id])
  userResponses UserResponse[]

  @@map("practice_sessions")
}

model UserResponse {
  id                  String   @id @default(uuid())
  sessionId           String
  questionId          String
  audioUrl            String?
  transcript          String?
  pronunciationScore  Json?
  contentScore        Json?
  overallScore        Float?
  feedback            String?
  evaluatedAt         DateTime?
  createdAt           DateTime @default(now())

  session  PracticeSession @relation(fields: [sessionId], references: [id])
  question Question        @relation(fields: [questionId], references: [id])

  @@unique([sessionId, questionId])
  @@map("user_responses")
}

model Payment {
  id              String        @id @default(uuid())
  userId          String
  orderCode       BigInt        @unique // PayOS order code (numeric)
  amount          Int           // VND
  description     String
  status          PaymentStatus @default(PENDING)
  tokenAmount     Int?          // Deprecated
  subscriptionId  String?       // Link to subscription if this payment is for subscription
  checkoutUrl     String?
  payosTransactionId String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@map("payments")
}

model SubscriptionPlan {
  id            SubscriptionPlanId @id
  name          String
  durationDays  Int
  price         Int                // VND
  pricePerMonth Int                // VND
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id        String             @id @default(uuid())
  userId    String
  planId    SubscriptionPlanId
  status    SubscriptionStatus @default(ACTIVE)
  
  startDate DateTime           @default(now())
  endDate   DateTime
  
  autoRenew Boolean            @default(false)
  
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan  @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([userId])
  @@index([status])
  @@index([endDate])
  @@map("subscriptions")
}

